{
    "version": 1,
    "project": "physicsnemo-curator",
    "project_url": "https://github.com/NVIDIA/physicsnemo-curator",
    "repo": ".",
    "branches": ["HEAD"],
    "dvcs": "git",
    "environment_type": "virtualenv",
    "show_commit_url": "https://github.com/NVIDIA/physicsnemo-curator/commit/",

    "build_command": [
        "python {build_dir}/benchmarks/asv_build.py"
    ],
    "install_command": [
        "in_dir={build_dir} python -m pip install --no-build-isolation -e {build_dir}"
    ],

    "matrix": {
        "fsspec": []
    },

    "benchmark_dir": "benchmarks",
    "env_dir": ".asv/env",
    "results_dir": ".asv/results",
    "html_dir": ".asv/html",
    "build_cache_size": 4,

    "regressions_thresholds": {
        ".*": 0.05
    }
}
